# OANDA API設定
# practice = デモ環境, live = 本番環境
OANDA_ENV=practice

# OANDAのAPIアクセストークン
OANDA_ACCESS_TOKEN=1c0780cade48feb56c093b8599efd38a-dd4c74c5053d2d8a4cd8a91e59216615

# OANDAの口座ID（例: 101-009-12345678-001）
