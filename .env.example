# LINE Notify通知設定（任意）
# https://notify-bot.line.me/ でトークンを取得
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# TradingView Webhook設定（任意）
# 任意の文字列を設定（TradingView側のアラートにも同じ値を設定）
WEBHOOK_SECRET=your_webhook_secret_here
